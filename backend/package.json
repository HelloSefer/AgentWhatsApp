{
  "name": "agent-whatsapp-backend",
  "version": "1.0.0",
  "description": "Backend for Moroccan Darija WhatsApp AI Sales Agent",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test:typing": "powershell -ExecutionPolicy Bypass -File .\\scripts\\test-typing-indicator.ps1",
    "db:migrate": "npm run build && node dist/infrastructure/database/migrations/migration.command.js migrate",
    "db:migrate:status": "npm run build && node dist/infrastructure/database/migrations/migration.command.js status",
    "test:database": "npm run build && node dist/infrastructure/database/testing/phase-7a-test.command.js",
    "test:seller-persistence": "npm run build && node dist/modules/seller/testing/phase-7b-test.command.js",
    "test:catalog-persistence": "npm run build && node dist/modules/catalog/testing/phase-7c-test.command.js",
    "test:conversation-config-persistence": "npm run build && node dist/modules/conversation-config/testing/phase-7d-test.command.js",
    "test:order-persistence": "npm run build && node dist/modules/agent/order/persistence/testing/phase-7e-test.command.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "puppeteer": "^25.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
