NODE_ENV=development
PORT=5000
APP_NAME=Moroccan Darija WhatsApp AI Sales Agent
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
INFORMATIONAL_AI_ENABLED=true
INFORMATIONAL_AI_TIMEOUT_MS=1500
WHATSAPP_PROVIDER=baileys
WHATSAPP_CLOUD_API_VERSION=v25.0
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_BUSINESS_ACCOUNT_ID=
WHATSAPP_CLOUD_VERIFY_TOKEN=agentwhatsapp_verify_123
WHATSAPP_CLOUD_APP_SECRET=
WHATSAPP_CLOUD_WEBHOOK_SIGNATURE_VERIFY=false
WHATSAPP_CLOUD_DRY_RUN=false
WHATSAPP_CLOUD_ALLOW_DEV_TOOLS=false
WHATSAPP_CLOUD_ORDER_FLOW_ID=
WHATSAPP_CLOUD_ORDER_FLOW_SCREEN_ID=ORDER_FORM
WHATSAPP_CLOUD_ORDER_FLOW_CTA=كملي معلومات الطلب
WHATSAPP_CLOUD_ORDER_FLOW_ON_ORDER_START=false
WHATSAPP_CLOUD_ORDER_FLOW_INITIAL_DATA_JSON=
PUBLIC_BASE_URL=
ORDER_FORM_FALLBACK_ENABLED=false
ORDER_FORM_FALLBACK_SEND_MODE=cta_url
ORDER_FORM_TOKEN_SECRET=
WHATSAPP_CLOUD_REPLY_BUTTONS_ENABLED=true
ORDER_RECEIPT_PDF_ENABLED=false
ORDER_RECEIPT_STORE_NAME=AN9A STORE
ORDER_RECEIPT_SUPPORT_PHONE=
ORDER_RECEIPT_LOGO_PATH=
ORDER_RECEIPT_OUTPUT_DIR=storage/receipts
ORDER_RECEIPT_SEND_TO_CUSTOMER=true
ORDER_RECEIPT_DELETE_AFTER_SEND=false
ORDER_RECEIPT_KEEP_FAILED_FILES=true
ORDER_RECEIPT_CLEANUP_ON_START=false
ORDER_RECEIPT_CLEANUP_MAX_AGE_HOURS=24
WHATSAPP_INTERACTIVE_ENABLED=false
WHATSAPP_INTERACTIVE_LIVE_SEND_ALLOWED=false
FIRST_ENTRY_LIVE_SMOKE_ENABLED=false
FIRST_ENTRY_LIVE_SMOKE_TEST_RECIPIENT=212600000000
FIRST_ENTRY_LIVE_SMOKE_SELLER_ID=seller_demo_sandals

# Live Natural AI is disabled by default for local PC because local models are too slow
# for realtime WhatsApp. Enable only when using faster hardware or remote Ollama/GPU.
NATURAL_REPLY_ENABLED=false
NATURAL_REPLY_MODEL=qwen2.5:0.5b
NATURAL_REPLY_TIMEOUT_MS=1500
NATURAL_REPLY_MAX_TOKENS=45
NATURAL_REPLY_TEMPERATURE=0.3
NATURAL_REPLY_TOP_P=0.8
NATURAL_REPLY_NUM_CTX=512
NATURAL_REPLY_WARMUP_ENABLED=false
VALKEY_URL=redis://localhost:6379
SESSION_TTL_SECONDS=172800
WHATSAPP_INTERACTIVE_CHOICES_ENABLED=true
WHATSAPP_INTERACTIVE_CHOICES_MODE=buttons_test
